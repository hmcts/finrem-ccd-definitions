/**
 * Build playwright command safely
 */
def buildPlaywrightCommand(tags, browser) {
    if (!tags?.trim()) {
        error('No tags supplied')
    }

    def tagList = tags
            .split(',')
            .collect { it.trim() }
            .findAll { it }

    tagList.each { tag ->
        if (!(tag ==~ /^@[A-Za-z0-9_-]+$/)) {
            error("Invalid tag supplied: ${tag}")
        }
    }

    def grepExpression = tagList
            .collect { java.util.regex.Pattern.quote(it) }
            .join('|')

    def command = "yarn playwright test --grep '${grepExpression}'"

    if (browser) {
        command += " --project=${browser}"
    }

    return command
}

/**
 * Reusable runner for each browser
 */
def runBrowser(name, command, reportDir) {
    try {
        yarnBuilder.yarn(command)
    } catch (Exception e) {
        unstable(message: "${name} failed: ${e.message}")
    } finally {
        publishHTML([
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: reportDir,
                reportFiles: 'index.html',
                reportName: "FunctionalTestReport-${name}"
        ])
    }
}

withNightlyPipeline(type, product, component) {

    env.NIGHTLY_TEST = 'true'
    env.NODE_ENV = 'ci'
    env.FUNCTIONAL_TESTS_WORKERS = params.FUNCTIONAL_TESTS_WORKERS
    env.RUNNING_ENV = params.RUNNING_ENV

    loadVaultSecrets(secrets)

    /**
     * SETUP
     */
    stage('Set up playwright') {
        yarnBuilder.yarn('yarn-update')
        yarnBuilder.yarn('install-dependencies')
        yarnBuilder.yarn('playwright install --with-deps')
        steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'definitions/**/xlsx/*.xlsx'
        env.ENV = params.RUNNING_ENV
    }

    /**
     * TEST EXECUTION
     */
    stage('Run tests') {

        if (!params.TAGS_TO_RUN?.trim()) {

            parallel(
                    edge: {
                        runBrowser('edge', 'test:functional-edge', 'playwright-report-edge')
                    },
                    chromium: {
                        runBrowser('chromium', 'test:functional-chromium', 'playwright-report-chromium')
                    },
                    chrome: {
                        runBrowser('chrome', 'test:functional-chrome', 'playwright-report-chrome')
                    },
                    firefox: {
                        runBrowser('firefox', 'test:functional-firefox', 'playwright-report-firefox')
                    },
                    webkit: {
                        runBrowser('webkit', 'test:functional-webkit', 'playwright-report-webkit')
                    }
            )

        } else {

            stage("${params.TAGS_TO_RUN} E2E Tests") {
                try {
                    def cmd = buildPlaywrightCommand(params.TAGS_TO_RUN, params.BROWSER_TO_RUN)
                    currentBuild.displayName = "${params.TAGS_TO_RUN} - ${params.BROWSER_TO_RUN}"
                    yarnBuilder.yarn(cmd)
                } catch (Exception e) {
                    unstable(message: "Tagged tests failed: ${e.message}")
                }
            }
        }
    }

    /**
     * CLEANUP (ALWAYS RUNS)
     */
    afterAlways('DependencyCheckNightly') {
        stage('Delete nightly dev branch') {
            try {
                echo "Cleaning up nightly branch..."
                yarnBuilder.yarn('delete-nightly-dev-branch finrem-ccd-definitions')
            } catch (Exception e) {
                unstable(message: "Cleanup unstable: ${e.message}")
            }
        }
    }
}